<script>
// ========== DATA ==========
const songs = [
  { id:1, name:'晴天', artist:'周杰伦', album:'叶惠美', dur:269, cover:'https://picsum.photos/seed/s1/200/200', liked:false,
    lyrics:['故事的小黄花','从出生那年就飘着','童年的荡秋千','随记忆一直晃到现在','Re So So Si Do Si La','So La Si Si Si Si La Si La So','吹着前奏 望着天空','我想起花瓣试着掉落'] },
