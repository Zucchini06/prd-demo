    lyrics:['这一路上走走停停','顺着少年漂流的痕迹','迈出车站的前一刻','竟有些犹豫','不禁笑这近乡情怯','仍无可避免'] },
  { id:5, name:'Counting Stars', artist:'OneRepublic', album:'Native', dur:258, cover:'https://picsum.photos/seed/s5/200/200', liked:false,
    lyrics:['Lately I\'ve been, I\'ve been losing sleep','Dreaming about the things that we could be','But baby I\'ve been, I\'ve been praying hard','Said no more counting dollars'] },
  { id:6, name:'戒烟', artist:'李荣浩', album:'耳朵', dur:288, cover:'https://picsum.photos/seed/s6/200/200', liked:false,
    lyrics:['已经为了变得更好','戒掉了浮躁 却难忘你的笑','我看着你的脸 轻刷着和弦','情人节卡片 手写的永远'] },
  { id:7, name:'Faded', artist:'Alan Walker', album:'Different World', dur:213, cover:'https://picsum.photos/seed/s7/200/200', liked:false,
    lyrics:['You were the shadow to my light','Did you feel us','Another start','You fade away'] },
  { id:8, name:'年少有为', artist:'李荣浩', album:'耳朵', dur:273, cover:'https://picsum.photos/seed/s8/200/200', liked:false,
    lyrics:['假如我年少有为不自卑','懂得什么是珍贵','那些美梦','没给你 我一生有愧'] },
  { id:9, name:'光年之外', artist:'邓紫棋', album:'光年之外', dur:233, cover:'https://picsum.photos/seed/s9/200/200', liked:false,
    lyrics:['感受停在我发端的指尖','如何瞬间 冻结时间','记住望着我坚定的双眼','也许已经 没有明天'] },
  { id:10, name:'Love Story', artist:'Taylor Swift', album:'Fearless', dur:236, cover:'https://picsum.photos/seed/s10/200/200', liked:false,
    lyrics:['We were both young when I first saw you','I close my eyes and the flashback starts','I\'m standing there','On a balcony in summer air'] },
  { id:11, name:'孤勇者', artist:'陈奕迅', album:'孤勇者', dur:271, cover:'https://picsum.photos/seed/s11/200/200', liked:false,
    lyrics:['都 是勇敢的','你额头的伤口 你的 不同 你犯的错','都 不必隐藏','你破旧的玩偶 你的 面具 你的自我'] },
  { id:12, name:'夜曲', artist:'周杰伦', album:'十一月的萧邦', dur:225, cover:'https://picsum.photos/seed/s12/200/200', liked:false,
    lyrics:['一群嗜血的蚂蚁 被腐肉所吸引','我面无表情 看孤独的风景','失去你 爱恨开始分明','失去你 还有什么事好关心'] }
];

let currentSongIdx = 0;
let isPlaying = false;
let lyricInterval = null;

function formatTime(s) { return Math.floor(s/60)+':'+String(s%60).padStart(2,'0'); }

// Build song list
function buildList() {
  const container = document.getElementById('songList');
  container.innerHTML = songs.map((s,i) => `
    <div class="song-item" id="song${i}"
         data-idx="${i}"
         ontouchstart="handleTouchStart(event,${i})"
         ontouchmove="handleTouchMove(event,${i})"
         ontouchend="handleTouchEnd(event,${i})"
         onclick="playSong(${i})">
      <div class="swipe-bg right">♥ 收藏</div>
      <div class="swipe-bg left">不喜欢</div>
      <span class="idx">${String(i+1).padStart(2,'0')}</span>
      <img class="cover" src="${s.cover}" alt="" loading="lazy" onerror="this.style.background='linear-gradient(135deg,'+['#667eea','#764ba2','#f093fb','#f5576c','#4facfe','#00f2fe','#43e97b','#fa709a'][i%8]+','+['#764ba2','#667eea','#f5576c','#f093fb','#00f2fe','#43e97b','#30cfd0','#f5576c'][i%8]+')'">
      <div class="info">
        <div class="name">${s.name}</div>
        <div class="artist">${s.artist} · ${s.album}</div>
      </div>
      <span class="dur">${formatTime(s.dur)}</span>
    </div>
  `).join('');
}

// Touch swipe
let touchStartX = 0, touchCurrentX = 0, touchActiveIdx = -1;
function handleTouchStart(e, idx) {
  touchStartX = e.touches[0].clientX;
  touchCurrentX = touchStartX;
  touchActiveIdx = idx;
}
function handleTouchMove(e, idx) {
  if (touchActiveIdx !== idx) return;
  touchCurrentX = e.touches[0].clientX;
  const dx = touchCurrentX - touchStartX;
  const el = document.getElementById('song'+idx);
  if (el) {
    if (Math.abs(dx) < 80 && Math.abs(dx) > 5) {
      el.style.transform = `translateX(${dx}px)`;
    }
  }
}
function handleTouchEnd(e, idx) {
  const dx = touchCurrentX - touchStartX;
  const el = document.getElementById('song'+idx);
  if (!el) { touchActiveIdx = -1; return; }
  el.style.transform = '';
  if (dx > 60) {
    songs[idx].liked = !songs[idx].liked;
    showToast(songs[idx].liked ? '已收藏 ♥' : '已取消收藏');
    buildList();
  } else if (dx < -60) {
    currentSongIdx = idx;
    showFeedback();
    buildList();
  }
  touchActiveIdx = -1;
}

// Demo: trigger dislike from tab button
function demoDislike() {
  currentSongIdx = Math.floor(Math.random() * songs.length);
  showFeedback();
}

// Page switching
function switchToPage(page) {
  const list = document.getElementById('listPage');
  const player = document.getElementById('playerPage');
  if (page === 'list') {
    list.className = 'page';
    player.className = 'page hidden-right';
    stopMusic();
    document.querySelectorAll('.tab').forEach((t,i) => t.classList.toggle('active', i===0));
  } else if (page === 'player') {
    list.className = 'page hidden-left';
    player.className = 'page';
    document.querySelectorAll('.tab').forEach((t,i) => t.classList.toggle('active', i===1));
  }
}

function playAll() { playSong(0); }

function playSong(idx) {
  currentSongIdx = idx;
  const s = songs[idx];
  document.getElementById('playerTitle').textContent = s.name + ' - ' + s.artist;
  document.getElementById('discCover').src = s.cover;
  document.getElementById('discCover').onerror = function() { this.style.background='linear-gradient(135deg,#667eea,#764ba2)'; };
  document.getElementById('playerBg').src = s.cover;
  document.getElementById('playerBg').onerror = function() { this.style.display='none'; };
  document.getElementById('totalTime').textContent = formatTime(s.dur);
  document.getElementById('curTime').textContent = '0:00';
  document.getElementById('trackFill').style.width = '0%';
  document.getElementById('actLike').className = s.liked ? 'act liked' : 'act';

  // Load lyrics
  const lyricArea = document.getElementById('lyricArea');
  if (s.lyrics && s.lyrics.length) {
    lyricArea.innerHTML = s.lyrics.map((l,i) =>
      `<div class="lyric-line ${i===0?'active':''}">${l}</div>`
    ).join('');
  } else {
    lyricArea.innerHTML = '<div class="lyric-line active" style="color:#fff;">纯音乐，请欣赏</div>';
  }

  document.getElementById('btnPlay').textContent = '▶';
  document.getElementById('disc').classList.remove('spinning','paused');
  switchToPage('player');
  startMusic();
}

function togglePlay() {
  if (isPlaying) {
    stopMusic();
    document.getElementById('btnPlay').textContent = '▶';
    document.getElementById('disc').classList.add('paused');
  } else {
    startMusic();
    document.getElementById('btnPlay').textContent = '❚❚';
    document.getElementById('disc').classList.remove('paused');
    document.getElementById('disc').classList.add('spinning');
  }
}

function startMusic() {
  isPlaying = true;
  document.getElementById('btnPlay').textContent = '❚❚';
  const disc = document.getElementById('disc');
  disc.classList.add('spinning');
  disc.classList.remove('paused');

  const s = songs[currentSongIdx];
  let elapsed = 0;
  if (lyricInterval) clearInterval(lyricInterval);
  lyricInterval = setInterval(() => {
    elapsed++;
    document.getElementById('curTime').textContent = formatTime(elapsed);
    document.getElementById('trackFill').style.width = (elapsed / s.dur * 100) + '%';

    // Lyric sync: scroll lyrics
    if (s.lyrics && s.lyrics.length) {
      const idx = Math.min(Math.floor(elapsed / (s.dur / s.lyrics.length)), s.lyrics.length-1);
      const lines = document.getElementById('lyricArea').querySelectorAll('.lyric-line');
      lines.forEach((l,i) => l.className = i===idx ? 'lyric-line active' : 'lyric-line');
      if (lines[idx]) lines[idx].scrollIntoView({block:'center',behavior:'smooth'});
    }

    if (elapsed >= s.dur) {
      clearInterval(lyricInterval);
      nextSong();
    }
  }, 980);
}

function stopMusic() {
  isPlaying = false;
  document.getElementById('btnPlay').textContent = '▶';
  document.getElementById('disc').classList.add('paused');
  if (lyricInterval) { clearInterval(lyricInterval); lyricInterval = null; }
}

function nextSong() {
  stopMusic();
  currentSongIdx = (currentSongIdx + 1) % songs.length;
  playSong(currentSongIdx);
}
function prevSong() {
  stopMusic();
  currentSongIdx = (currentSongIdx - 1 + songs.length) % songs.length;
  playSong(currentSongIdx);
}

function toggleLike() {
  songs[currentSongIdx].liked = !songs[currentSongIdx].liked;
  document.getElementById('actLike').className = songs[currentSongIdx].liked ? 'act liked' : 'act';
  showToast(songs[currentSongIdx].liked ? '已收藏 ♥' : '已取消收藏');
}

// Feedback
let selectedReasons = [];
function showFeedback() {
  selectedReasons = [];
  document.querySelectorAll('#reasonGrid .reason-chip').forEach(c => c.classList.remove('selected'));
  document.querySelector('#feedbackModal textarea').value = '';
  document.getElementById('feedbackModal').classList.add('show');
}
function hideFeedback() {
  document.getElementById('feedbackModal').classList.remove('show');
}
function toggleReason(el) {
  el.classList.toggle('selected');
  if (el.classList.contains('selected')) {
    selectedReasons.push(el.textContent);
  } else {
    selectedReasons = selectedReasons.filter(r => r !== el.textContent);
  }
}
function submitFeedback() {
  const text = document.querySelector('#feedbackModal textarea').value;
  const reasons = selectedReasons.length ? selectedReasons.join('、') : '未选择';
  hideFeedback();
  showToast('我们会优化你的推荐');
  // Remove song from list with animation
  setTimeout(() => {
    const el = document.getElementById('song'+currentSongIdx);
    if (el) {
      el.style.transition = 'all 0.3s';
      el.style.opacity = '0';
      el.style.transform = 'translateX(-100%)';
      el.style.maxHeight = '0';
      el.style.padding = '0';
      el.style.margin = '0';
      el.style.overflow = 'hidden';
    }
  }, 300);
}

function showToast(msg) {
  const toast = document.getElementById('toast');
  toast.textContent = msg;
  toast.classList.add('show');
  setTimeout(() => toast.classList.remove('show'), 2000);
}

// Init
buildList();
</script>

